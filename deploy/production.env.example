NODEWATCH_IMAGE=ghcr.io/请替换为GitHub用户名/nodewatch:v0.1.1
POSTGRES_IMAGE=ghcr.io/请替换为GitHub用户名/nodewatch-postgres:17-alpine-v0.1.1
APP_VERSION=0.1.1
LOG_LEVEL=INFO

POSTGRES_USER=nodewatch
POSTGRES_PASSWORD=请替换为随机生成的数据库密码
POSTGRES_DB=nodewatch
SECRET_KEY=请替换为至少32字符的随机密钥

ALLOWED_HOSTS=请替换为公网IP
SESSION_COOKIE_NAME=nodewatch_session
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=true

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=请替换为首次登录专用强密码

DEFAULT_COLLECT_INTERVAL_SECONDS=60
MAX_AGENT_BATCH_SAMPLES=500
OFFLINE_AFTER_SECONDS=180
RAW_METRIC_RETENTION_DAYS=30
